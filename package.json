{
  "name": "nature-connected-professionals-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24.17.0 <25"
  },
  "scripts": {
    "sync-content": "node scripts/fetch-contentful.mjs",
    "bootstrap-contentful-model": "node scripts/bootstrap-contentful-model.mjs",
    "seed-contentful": "node scripts/seed-contentful.mjs",
