---
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  formatEventWhen,
  getPageBySlug,
  getSiteSettings,
  getUpcomingEvents
} from '../lib/content.js';
import { assetUrl, resolveHref } from '../lib/sitePath.js';
import { renderMarkdown, renderMarkdownInline } from '../lib/markdown.js';
import Lightbox from '../components/Lightbox.astro';

const site = getSiteSettings();
const page = getPageBySlug('gatherings');
const upcoming = getUpcomingEvents();

if (!page) {
  throw new Error('Missing required standard page content for slug "gatherings".');
}
---

<BaseLayout
  title={`${page.title} | ${site.organizationName}`}
  description={page.intro || page.title}
  image={page.heroImageUrl || '/images/placeholders/hero-nature.svg'}
>
  {
    page.heroImageUrl ? (
      <section
        class="hero-block hero-block--media hero-block--image-first-mobile"
        aria-labelledby="gatherings-title"
      >
        <div class="hero-copy hero-copy--vcenter">
          <h1 id="gatherings-title">{page.title}</h1>
          {page.intro ? <p class="lead-text">{page.intro}</p> : null}
        </div>
        <img
          class="placeholder-image placeholder-image--hero"
          src={assetUrl(page.heroImageUrl)}
          alt={page.heroImageAlt || `${page.title} hero image`}
          loading="lazy"
        />
      </section>
    ) : (
      <section class="hero-block" aria-labelledby="gatherings-title">
        <h1 id="gatherings-title">{page.title}</h1>
        {page.intro ? <p class="lead-text">{page.intro}</p> : null}
      </section>
    )
  }

  {
    (page.infoCards ?? []).map((card, i) => (
      <section
        class="section-stack"
        aria-labelledby={card.title ? `gatherings-info-card-${i}` : undefined}
        aria-label={card.title ? undefined : 'Information'}
      >
        {card.title ? <h2 id={`gatherings-info-card-${i}`}>{card.title}</h2> : null}
        {card.description ? <p class="page-body">{card.description}</p> : null}
        {card.href ? (
          <p>
            <a class="button button--compact" href={resolveHref(card.href)}>
              Learn more
            </a>
          </p>
        ) : null}
      </section>
    ))
  }

  {
    page.sections.map((section) => (
      <section class="section-stack" aria-label={section.heading || 'Page section'}>
        {section.heading ? <h2>{section.heading}</h2> : null}
        {section.bodyText ? <p class="page-body">{section.bodyText}</p> : null}

        {section.cards?.length ? (
          <div class="card-grid">
            {section.cards.map((card) => (
              <article class="card">
                <h3>{card.title}</h3>
                <p>{card.description}</p>
              </article>
            ))}
          </div>
        ) : null}

        {section.listItems?.length ? (
          <ul class="list-flow">
            {section.listItems.map((item) => <li>{item}</li>)}
          </ul>
        ) : null}
      </section>
    ))
  }

  {
    upcoming.length ? (
      upcoming.map((event, i) => (
        <section class="section-stack gathering-event-section" aria-labelledby={`gathering-event-${i}-title`}>
          <div class="gathering-event-body event-item--media">
            <div class="gathering-event-media">
              {event.image ? (
                <a
                  class="event-thumb-link"
                  href={assetUrl(event.image)}
                  data-lightbox
                  data-lightbox-alt={`Event image for ${event.title}`}
                  aria-label={`View larger image for ${event.title}`}
                >
                  <img
                    class="event-thumb"
                    src={assetUrl(event.image)}
                    alt={`Event image for ${event.title}`}
                    loading="lazy"
                  />
                </a>
              ) : null}
              {event.registrationUrl ? (
                <div class="event-cta-row event-cta-row--media">
                  <a
                    class="button button--compact"
                    href={resolveHref(event.registrationUrl)}
                    target="_blank"
                    rel="noopener noreferrer"
                  >Register</a>
                </div>
              ) : null}
            </div>
            <div>
              <h2 id={`gathering-event-${i}-title`}>{event.title}</h2>
              <p class="meta-text">
                <span class="event-when--tbd">{formatEventWhen(event)}</span>
              </p>
              {event.location ? (
                <div class="event-location" aria-label="Location">
                  <span class="event-location__icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M12 21s-7-7.5-7-12a7 7 0 1 1 14 0c0 4.5-7 12-7 12z" />
                      <circle cx="12" cy="9" r="2.5" />
                    </svg>
                  </span>
                  <span class="event-location__text markdown markdown--inline" set:html={renderMarkdownInline(event.location)} />
                </div>
              ) : null}
              {event.details ? (
                <div class="markdown" set:html={renderMarkdown(event.details)} />
              ) : null}
              {event.specialInfo ? (
                <aside class="event-special-info" aria-label="Special note">
                  <span class="event-special-info__rule" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" width="14" height="14" focusable="false">
                      <path fill="currentColor" d="M8 0l1.9 6.1L16 8l-6.1 1.9L8 16l-1.9-6.1L0 8l6.1-1.9z" />
                    </svg>
                  </span>
                  <div class="event-special-info__text markdown" set:html={renderMarkdown(event.specialInfo)} />
                </aside>
              ) : null}
            </div>
          </div>
        </section>
      ))
    ) : (
      <p class="lead-text">No upcoming gatherings are posted yet.</p>
    )
  }

  <Lightbox />
</BaseLayout>
