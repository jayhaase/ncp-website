---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getSiteSettings, getUpcomingEvents } from '../lib/content.js';
import { assetUrl, resolveHref } from '../lib/sitePath.js';

const site = getSiteSettings();
const upcoming = getUpcomingEvents();
---

<BaseLayout
  title={`Gatherings | ${site.organizationName}`}
  description="Seasonal gatherings and unconference-style events"
>
  <section
    class="hero-block hero-block--media hero-block--gatherings hero-block--image-first-mobile"
    aria-labelledby="gatherings-title"
  >
    <div class="hero-copy">
      <h1 id="gatherings-title">Events and Gatherings</h1>
      <p class="lead-text">
        Seasonal gatherings and unconference-style sessions support practical collaboration and relationship-building.
      </p>
    </div>
    <img
      class="placeholder-image placeholder-image--hero"
      src={assetUrl('/images/placeholders/tree.png')}
      alt="Stylized tree illustration for gatherings page"
      loading="lazy"
    />
  </section>

  {
    upcoming.length ? (
      upcoming.map((event, i) => (
        <section class="section-stack gathering-event-section" aria-labelledby={`gathering-event-${i}-title`}>
          <div class="gathering-event-body event-item--media">
            {event.image ? (
              <img
                class="event-thumb"
                src={assetUrl(event.image)}
                alt={`Event image for ${event.title}`}
                loading="lazy"
              />
            ) : null}
            <div>
              <h2 id={`gathering-event-${i}-title`}>{event.title}</h2>
              <p class="meta-text">
                <time datetime={event.startDate}>{new Date(event.startDate).toLocaleString()}</time>
                {event.endDate ? ` to ${new Date(event.endDate).toLocaleString()}` : ''}
              </p>
              {event.location ? <p class="meta-text">{event.location}</p> : null}
              {event.summary ? <p>{event.summary}</p> : null}
              {event.details ? <p>{event.details}</p> : null}
              <div class="event-cta-row">
                <a class="button button--compact" href={resolveHref(event.registrationUrl || '/connect')}>Register</a>
              </div>
            </div>
          </div>
        </section>
      ))
    ) : (
      <p class="lead-text">No upcoming gatherings are posted yet.</p>
    )
  }
</BaseLayout>
