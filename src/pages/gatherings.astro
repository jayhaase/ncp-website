---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPastEvents, getSiteSettings, getUpcomingEvents } from '../lib/content.js';

const site = getSiteSettings();
const upcoming = getUpcomingEvents();
const past = getPastEvents();
---

<BaseLayout
  title={`Gatherings | ${site.organizationName}`}
  description="Seasonal gatherings and unconference-style events"
>
  <section class="hero-block hero-block--media" aria-labelledby="gatherings-title">
    <div class="hero-copy">
      <h1 id="gatherings-title">Events and Gatherings</h1>
      <p class="lead-text">
        Seasonal gatherings and unconference-style sessions support practical collaboration and relationship-building.
      </p>
    </div>
    <img
      class="placeholder-image placeholder-image--hero"
      src="/images/placeholders/gathering-circle.svg"
      alt="Placeholder illustration for gatherings page"
      loading="lazy"
    />
  </section>

  <section class="section-stack" aria-labelledby="upcoming-title">
    <h2 id="upcoming-title">Upcoming gatherings</h2>
    {
      upcoming.length ? (
        <div class="event-list">
          {upcoming.map((event) => (
            <article class="event-item">
              <h3>{event.title}</h3>
              <p class="meta-text">
                <time datetime={event.startDate}>{new Date(event.startDate).toLocaleString()}</time>
                {event.endDate ? ` to ${new Date(event.endDate).toLocaleString()}` : ''}
              </p>
              {event.location ? <p class="meta-text">{event.location}</p> : null}
              {event.summary ? <p>{event.summary}</p> : null}
              {event.details ? <p>{event.details}</p> : null}
              {event.registrationUrl ? (
                <a class="text-link" href={event.registrationUrl}>Registration details</a>
              ) : null}
            </article>
          ))}
        </div>
      ) : (
        <p>No upcoming gatherings are posted yet.</p>
      )
    }
  </section>

  <section class="section-stack" aria-labelledby="past-title">
    <h2 id="past-title">Past gatherings</h2>
    {
      past.length ? (
        <div class="event-list">
          {past.map((event) => (
            <article class="event-item">
              <h3>{event.title}</h3>
              <p class="meta-text">
                <time datetime={event.startDate}>{new Date(event.startDate).toLocaleDateString()}</time>
                {event.location ? ` · ${event.location}` : ''}
              </p>
              {event.summary ? <p>{event.summary}</p> : null}
            </article>
          ))}
        </div>
      ) : (
        <p>Past gathering details will be added soon.</p>
      )
    }
  </section>
</BaseLayout>
