---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPageBySlug, getSiteSettings } from '../lib/content.js';
import { getDirectoryEntries } from '../lib/directory.js';
import { assetUrl, resolveHref } from '../lib/sitePath.js';

const site = getSiteSettings();
const page = getPageBySlug('directory');
const members = getDirectoryEntries();
const placeholderPhoto = assetUrl('/images/placeholders/directory-avatar.svg');

if (!page) {
  throw new Error('Missing required standard page content for slug "directory".');
}

function resolveMemberPhoto(photoUrl: string | null) {
  if (!photoUrl) return placeholderPhoto;
  if (photoUrl.startsWith('/')) return assetUrl(photoUrl);
  return photoUrl;
}

/** One list item per line; strips common leading markers from CSV/Airtable exports. */
function splitIntoBulletItems(text: string) {
  const raw = String(text || '').trim();
  if (!raw) return [];

  const items = raw
    .split(/\r?\n+/)
    .map((line) =>
      line
        .trim()
        .replace(/^['\u2018\u2019]\s*/, '')
        .replace(/^[-*•\u2022]\s+/, '')
        .replace(/^\d+[.)]\s+/, '')
        .trim()
    )
    .filter(Boolean);

  return items.length ? items : [raw];
}
---

<BaseLayout
  title={`${page.title} | ${site.organizationName}`}
  description={page.intro || page.title}
  image={page.heroImageUrl || '/images/placeholders/hero-nature.svg'}
>
  {
    page.heroImageUrl ? (
      <section
        class="hero-block hero-block--media hero-block--image-first-mobile"
        aria-labelledby="directory-title"
      >
        <div class="hero-copy hero-copy--vcenter">
          <h1 id="directory-title">{page.title}</h1>
          {page.intro ? <p class="lead-text">{page.intro}</p> : null}
        </div>
        <img
          class="placeholder-image placeholder-image--hero"
          src={assetUrl(page.heroImageUrl)}
          alt={page.heroImageAlt || `${page.title} hero image`}
          loading="lazy"
        />
      </section>
    ) : (
      <section class="hero-block" aria-labelledby="directory-title">
        <h1 id="directory-title">{page.title}</h1>
        {page.intro ? <p class="lead-text">{page.intro}</p> : null}
      </section>
    )
  }

  {
    page.infoCards?.length ? (
      <div class="info-card-grid" aria-label="Information">
        {(page.infoCards ?? []).map((card, i) => (
          <section
            class="section-stack"
            aria-labelledby={card.title ? `directory-info-card-${i}` : undefined}
            aria-label={card.title ? undefined : 'Information'}
          >
            {card.title ? <h2 id={`directory-info-card-${i}`}>{card.title}</h2> : null}
            {card.description ? <p class="page-body">{card.description}</p> : null}
            {card.href ? (
              <p>
                <a class="button button--compact" href={resolveHref(card.href)}>
                  Learn more
                </a>
              </p>
            ) : null}
          </section>
        ))}
      </div>
    ) : null
  }

  {
    page.sections.map((section) => (
      <section class="section-stack" aria-label={section.heading || 'Page section'}>
        {section.heading ? <h2>{section.heading}</h2> : null}
        {section.bodyText ? <p class="page-body">{section.bodyText}</p> : null}

        {section.cards?.length ? (
          <div class="card-grid">
            {section.cards.map((card) => (
              <article class="card">
                <h3>{card.title}</h3>
                <p>{card.description}</p>
              </article>
            ))}
          </div>
        ) : null}

        {section.listItems?.length ? (
          <ul class="list-flow">
            {section.listItems.map((item) => <li>{item}</li>)}
          </ul>
        ) : null}
      </section>
    ))
  }

  <div class="directory-page">
    <div class="directory-page__header">
      <p class="meta-text directory-count">{members.length} listings</p>
    </div>

    <ul class="directory-list" aria-label="Directory listings">
      {
        members.map((member) => {
          const photoSrc = resolveMemberPhoto(member.photoUrl);
          const hasPhoto = Boolean(member.photoUrl);
          return (
            <li>
              <article class="directory-card">
                <div class="directory-card__layout">
                  <img
                    class="directory-card__photo"
                    src={photoSrc}
                    alt={hasPhoto ? `Photo of ${member.displayName}` : ''}
                    loading="lazy"
                    width="320"
                    height="320"
                  />
                  <div class="directory-card__main">
                    <header class="directory-card__header">
                      <h3 class="directory-card__name">{member.displayName}</h3>
                      {member.organization ? <p class="directory-card__org">{member.organization}</p> : null}
                      {member.pronouns ? <p class="meta-text directory-card__pronouns">{member.pronouns}</p> : null}
                    </header>

                    <div class="directory-card__actions">
                      {member.email ? (
                        <a class="button button--compact" href={`mailto:${member.email}`}>
                          Email
                        </a>
                      ) : null}
                      {member.website ? (
                        <a
                          class="button button--secondary button--compact"
                          href={member.website}
                          target="_blank"
                          rel="noopener noreferrer"
                        >
                          Website
                        </a>
                      ) : null}
                    </div>

                    {member.services ? (
                      <div class="directory-card__field">
                        <h4 class="directory-card__label">Services</h4>
                        <ul class="directory-card__list">
                          {splitIntoBulletItems(member.services).map((item) => (
                            <li>{item}</li>
                          ))}
                        </ul>
                      </div>
                    ) : null}

                    {member.certifications && member.certifications.toLowerCase() !== 'na' ? (
                      <div class="directory-card__field">
                        <h4 class="directory-card__label">Nature-based certifications &amp; credentials</h4>
                        <ul class="directory-card__list">
                          {splitIntoBulletItems(member.certifications).map((item) => (
                            <li>{item}</li>
                          ))}
                        </ul>
                      </div>
                    ) : null}
                  </div>
                </div>
              </article>
            </li>
          );
        })
      }
    </ul>
  </div>
</BaseLayout>
