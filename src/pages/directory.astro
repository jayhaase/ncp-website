---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getSiteSettings } from '../lib/content.js';

const site = getSiteSettings();
---

<BaseLayout
  title={`Directory | ${site.organizationName}`}
  description="Browse the member directory."
  embedFillHeight
>
  <section class="directory-embed" aria-label="Directory">
    <iframe
      class="airtable-embed"
      src="https://airtable.com/embed/appsMUuZqzzwwu4Wp/shrQIKbbvgCQdYeTz?viewControls=on"
      width="100%"
      style="background: transparent;"
      title="Member directory"
    ></iframe>
  </section>
</BaseLayout>
