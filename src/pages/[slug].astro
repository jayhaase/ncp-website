---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPageBySlug, getRoutableStandardPages, getSiteSettings } from '../lib/content.js';

const site = getSiteSettings();

export async function getStaticPaths() {
  const pages = getRoutableStandardPages();
  return pages.map((page) => ({
    params: { slug: page.slug }
  }));
}

const { slug } = Astro.params;
const page = getPageBySlug(slug);

if (!page || slug === 'gatherings') {
  return Astro.redirect('/');
}
---

<BaseLayout title={`${page.title} | ${site.organizationName}`} description={page.intro || page.title}>
  <section class="hero-block" aria-labelledby="standard-page-title">
    <h1 id="standard-page-title">{page.title}</h1>
    {page.intro ? <p class="lead-text">{page.intro}</p> : null}
  </section>

  {
    slug === 'about' || slug === 'connect' ? (
      <>
        <section class="section-stack identity-section" aria-labelledby={`${slug}-static-card-1`}>
          <h2 id={`${slug}-static-card-1`}>Lorem ipsum dolor</h2>
          <p class="page-body standard-page-card__text">
            Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et
            dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris.
          </p>
        </section>
        <section class="section-stack identity-section" aria-labelledby={`${slug}-static-card-2`}>
          <h2 id={`${slug}-static-card-2`}>Sit amet consectetur</h2>
          <p class="page-body standard-page-card__text">
            Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur.
            Excepteur sint occaecat cupidatat non proident, sunt in culpa qui officia deserunt mollit anim id est
            laborum.
          </p>
        </section>
      </>
    ) : null
  }

  {
    page.sections.map((section) => (
      <section class="section-stack" aria-label={section.heading || 'Page section'}>
        {section.heading ? <h2>{section.heading}</h2> : null}
        {section.bodyText ? <p class="page-body">{section.bodyText}</p> : null}

        {section.cards?.length ? (
          <div class="card-grid">
            {section.cards.map((card) => (
              <article class="card">
                <h3>{card.title}</h3>
                <p>{card.description}</p>
              </article>
            ))}
          </div>
        ) : null}

        {section.listItems?.length ? (
          <ul class="list-flow">
            {section.listItems.map((item) => <li>{item}</li>)}
          </ul>
        ) : null}
      </section>
    ))
  }
</BaseLayout>
