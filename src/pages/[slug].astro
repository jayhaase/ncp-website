---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPageBySlug, getRoutableStandardPages, getSiteSettings } from '../lib/content.js';
import { assetUrl, resolveHref } from '../lib/sitePath.js';

const site = getSiteSettings();

export async function getStaticPaths() {
  const pages = getRoutableStandardPages();
  return pages.map((page) => ({
    params: { slug: page.slug }
  }));
}

const { slug } = Astro.params;
const page = getPageBySlug(slug);

if (!page || slug === 'gatherings') {
  return Astro.redirect('/');
}
---

<BaseLayout title={`${page.title} | ${site.organizationName}`} description={page.intro || page.title}>
  {
    page.heroImageUrl ? (
      <section
        class="hero-block hero-block--media hero-block--image-first-mobile"
        aria-labelledby="standard-page-title"
      >
        <div class="hero-copy">
          <h1 id="standard-page-title">{page.title}</h1>
          {page.intro ? <p class="lead-text">{page.intro}</p> : null}
        </div>
        <img
          class="placeholder-image placeholder-image--hero"
          src={assetUrl(page.heroImageUrl)}
          alt={page.heroImageAlt || `${page.title} hero image`}
          loading="lazy"
        />
      </section>
    ) : (
      <section class="hero-block" aria-labelledby="standard-page-title">
        <h1 id="standard-page-title">{page.title}</h1>
        {page.intro ? <p class="lead-text">{page.intro}</p> : null}
      </section>
    )
  }

  {
    (page.infoCards ?? []).map((card, i) => (
      <section
        class="section-stack"
        aria-labelledby={card.title ? `info-card-${slug}-${i}` : undefined}
        aria-label={card.title ? undefined : 'Information'}
      >
        {card.title ? <h2 id={`info-card-${slug}-${i}`}>{card.title}</h2> : null}
        {card.description ? <p class="page-body">{card.description}</p> : null}
        {card.href ? (
          <p>
            <a class="button button--compact" href={resolveHref(card.href)}>
              Learn more
            </a>
          </p>
        ) : null}
      </section>
    ))
  }

  {
    page.sections.map((section) => (
      <section class="section-stack" aria-label={section.heading || 'Page section'}>
        {section.heading ? <h2>{section.heading}</h2> : null}
        {section.bodyText ? <p class="page-body">{section.bodyText}</p> : null}

        {section.cards?.length ? (
          <div class="card-grid">
            {section.cards.map((card) => (
              <article class="card">
                <h3>{card.title}</h3>
                <p>{card.description}</p>
              </article>
            ))}
          </div>
        ) : null}

        {section.listItems?.length ? (
          <ul class="list-flow">
            {section.listItems.map((item) => <li>{item}</li>)}
          </ul>
        ) : null}
      </section>
    ))
  }
</BaseLayout>
