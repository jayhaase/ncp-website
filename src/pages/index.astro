---
import BaseLayout from '../layouts/BaseLayout.astro';
import { formatEventWhen, getHomeContent, getSiteSettings, getUpcomingEvents } from '../lib/content.js';
import { assetUrl, resolveHref, sitePath } from '../lib/sitePath.js';
import { renderMarkdown } from '../lib/markdown.js';
import Lightbox from '../components/Lightbox.astro';

const site = getSiteSettings();
const home = getHomeContent();
const displayEvents = getUpcomingEvents().slice(0, 1);
---

<BaseLayout title={site.organizationName} description={home.description || home.title} image={home.heroImageUrl}>
  <section class="hero-block hero-block--media hero-block--image-first-mobile" aria-labelledby="home-hero-title">
    <div class="hero-copy">
      <h1 id="home-hero-title">{home.title}</h1>
      {home.description ? <p class="lead-text">{home.description}</p> : null}
    </div>
    <img
      class="placeholder-image placeholder-image--hero"
      src={assetUrl(home.heroImageUrl || '/images/placeholders/hero-nature.svg')}
      alt={home.heroImageAlt || 'Homepage hero image'}
      loading="lazy"
    />
  </section>

  <section class="section-stack" aria-labelledby="events-preview-title">
    <div class="section-header-row">
      <h2 id="events-preview-title">Our Next Gathering</h2>
    </div>
    {
      displayEvents.length ? (
        <div>
          <div class="gathering-preview-list">
            {displayEvents.map((event) => (
              <article class="gathering-preview-item gathering-preview-item--media">
                {event.image ? (
                  <a
                    class="event-thumb-link"
                    href={assetUrl(event.image)}
                    data-lightbox
                    data-lightbox-alt={`Event image for ${event.title}`}
                    aria-label={`View larger image for ${event.title}`}
                  >
                    <img
                      class="event-thumb"
                      src={assetUrl(event.image)}
                      alt={`Event image for ${event.title}`}
                      loading="lazy"
                    />
                  </a>
                ) : null}
                <div>
                  <h3>{event.title}</h3>
                  <p class="meta-text">
                    <span class="event-when--tbd">{formatEventWhen(event)}</span>
                  </p>
                {event.summary ? (
                  <div class="markdown" set:html={renderMarkdown(event.summary)} />
                ) : null}
                <div class="event-cta-row">
                  {event.registrationUrl ? (
                    <a
                      class="button button--compact"
                      href={resolveHref(event.registrationUrl)}
                      target="_blank"
                      rel="noopener noreferrer"
                    >Register</a>
                  ) : null}
                  <a class="button button--secondary button--compact" href={sitePath('/gatherings')}>View all gatherings</a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
      ) : (
        <p>No upcoming gatherings are posted yet.</p>
      )
    }
  </section>

  <section class="section-stack identity-section" aria-labelledby="identity-title">
    <h2 id="identity-title">Who We Are &amp; Why We Exist</h2>
    {home.mission ? <div class="markdown lead-text" set:html={renderMarkdown(home.mission)} /> : null}
    <div class="identity-grid">
      {home.highlightCards.map((card) => (
        <article class="identity-item">
          <h3>{card.title}</h3>
          <p>{card.description}</p>
        </article>
      ))}
    </div>
  </section>

  {
    home.newsletter ? (
      <section class="newsletter-section" aria-labelledby="newsletter-title">
        <h2 id="newsletter-title">{home.newsletter.title}</h2>
        {home.newsletter.description ? <p class="lead-text">{home.newsletter.description}</p> : null}
        {home.newsletter.url ? (
          <div class="button-row">
            <a
              class="button"
              href={resolveHref(home.newsletter.url)}
              target="_blank"
              rel="noopener noreferrer"
            >
              {home.newsletter.ctaLabel || 'Subscribe'}
            </a>
          </div>
        ) : null}
      </section>
    ) : null
  }

  <Lightbox />
</BaseLayout>
