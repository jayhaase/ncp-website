---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getHomeContent, getSiteSettings, getUpcomingEvents } from '../lib/content.js';
import { assetUrl, resolveHref, sitePath } from '../lib/sitePath.js';

const site = getSiteSettings();
const home = getHomeContent();
const displayEvents = getUpcomingEvents().slice(0, 1);
---

<BaseLayout title={site.organizationName} description={home.description}>
  <section class="hero-block hero-block--media hero-block--image-first-mobile" aria-labelledby="home-hero-title">
    <div class="hero-copy">
      <h1 id="home-hero-title">{home.title}</h1>
      {home.description ? <p class="lead-text">{home.description}</p> : null}
      <div class="button-row">
        <a class="button" href={resolveHref(site.primaryCta.url)}>{site.primaryCta.label}</a>
        <a class="button button--secondary" href={sitePath('/gatherings')}>Explore gatherings</a>
      </div>
    </div>
    <img
      class="placeholder-image placeholder-image--hero"
      src={assetUrl(home.heroImageUrl || '/images/placeholders/hero-nature.svg')}
      alt={home.heroImageAlt || 'Homepage hero image'}
      loading="lazy"
    />
  </section>

  <section class="section-stack" aria-labelledby="events-preview-title">
    <div class="section-header-row">
      <h2 id="events-preview-title">Our Next Gathering</h2>
    </div>
    {
      displayEvents.length ? (
        <div>
          <div class="gathering-preview-list">
            {displayEvents.map((event) => (
              <article class="gathering-preview-item gathering-preview-item--media">
                {event.image ? (
                  <img
                    class="event-thumb"
                    src={assetUrl(event.image)}
                    alt={`Event image for ${event.title}`}
                    loading="lazy"
                  />
                ) : null}
                <div>
                  <h3>{event.title}</h3>
                <p class="meta-text">
                  <time datetime={event.startDate}>{new Date(event.startDate).toLocaleDateString()}</time>
                  {' · '}
                  {event.location}
                </p>
                <p>{event.summary}</p>
                <div class="event-cta-row">
                  <a class="button button--compact" href={resolveHref(event.registrationUrl || '/connect')}>Register</a>
                  <a class="button button--secondary button--compact" href={sitePath('/gatherings')}>View all gatherings</a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
      ) : (
        <p>No upcoming gatherings are posted yet.</p>
      )
    }
  </section>

  <section class="section-stack identity-section" aria-labelledby="identity-title">
    <h2 id="identity-title">Who We Are &amp; Why We Exist</h2>
    <p class="lead-text">
      Nature Connected Professionals is a community for people who believe that meaningful work and a meaningful life are rooted in connection — to nature, to each other, and to something larger than ourselves.
    </p>
    <div class="identity-grid">
      <article class="identity-item">
        <h3>Cultivate Depth</h3>
        <p>Build genuine community through intentional gathering and shared experience.</p>
      </article>
      <article class="identity-item">
        <h3>Engage Broadly</h3>
        <p>Expand your network with professionals who share your values.</p>
      </article>
      <article class="identity-item">
        <h3>Steward Care</h3>
        <p>Generously share skills, knowledge, and the wisdom of experience.</p>
      </article>
    </div>
  </section>

  <section class="section-stack how-section" aria-labelledby="how-title">
    <h2 id="how-title">How this works</h2>
    <p class="lead-text">
      Simple, grounded, and designed for real connection. No complicated systems — just clear pathways to get involved at whatever level feels right for you.
    </p>
    <div class="how-list">
      <article class="how-item">
        <h3><span aria-hidden="true">🌲</span> Attend a Gathering</h3>
        <p>Join a seasonal gathering — held outdoors, in community, with space for honest conversation.</p>
        <a class="how-action" href={sitePath('/gatherings')}>Explore</a>
      </article>
      <article class="how-item">
        <h3><span aria-hidden="true">💬</span> Connect Online</h3>
        <p>Join our Slack community to stay in touch, share resources, and find collaborators between events.</p>
        <a class="how-action" href={sitePath('/connect')}>Connect</a>
      </article>
      <article class="how-item">
        <h3><span aria-hidden="true">📇</span> Join the Directory</h3>
        <p>Add yourself to the member directory so others can find and reach out to you.</p>
        <a class="how-action" href={sitePath('/connect')}>Join</a>
      </article>
      <article class="how-item">
        <h3><span aria-hidden="true">🤝</span> Participate &amp; Contribute</h3>
        <p>Propose a session, share your expertise, or simply show up and be present.</p>
        <a class="how-action" href={sitePath('/connect')}>Participate</a>
      </article>
    </div>
  </section>

</BaseLayout>
