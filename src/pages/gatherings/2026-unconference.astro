---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getSiteSettings } from '../../lib/content.js';
import { assetUrl, sitePath } from '../../lib/sitePath.js';

const site = getSiteSettings();

const pillars = [
  {
    title: 'Connection',
    body:
      'The primary reason we are here. We gather to belong within the community and to undo aloneness in the field.'
  },
  {
    title: 'Reciprocity',
    body:
      'The intent is to foster relational reciprocity with humans and the more-than-human world.'
  },
  {
    title: 'Justice',
    body:
      'Many of us are working to decolonize our practices. We hold space for that work in how we gather, what we offer, and who we invite into the circle.'
  }
];

const streams = [
  {
    icon: '🌳',
    name: 'The Great Tree',
    kind: 'Formal presentations and workshops',
    body:
      "Offering ideas and practices on a topic through a presentation or workshop."
  },
  {
    icon: '🔥',
    name: 'Campfire Conversations',
    kind: 'Facilitated conversations',
    body:
      'Facilitating a shared conversation about a topic without a specific agenda.'
  },
  {
    icon: '☕',
    name: 'Community Cafe',
    kind: 'Lightning talks, posters, and tabling',
    body:
      'A third-space for encounters and explorations. Spontaneous sparks that must be shared.'
  }
];

const schedule = [
  { time: '9:00 – 10:00 am', title: 'Opening Circle', body: 'Grounding together and welcoming the land.' },
  { time: '10:00 – 11:00 am', title: 'Session Block 1', body: 'Three streams running in parallel.' },
  { time: '11:00 am – 12:00 pm', title: 'Session Block 2', body: 'Three streams running in parallel.' },
  { time: '12:00 – 1:00 pm', title: 'Lunch', body: 'Food trucks and open time together.' },
  { time: '1:00 – 2:00 pm', title: 'Session Block 3', body: 'Three streams running in parallel.' },
  { time: '2:00 – 3:00 pm', title: 'Session Block 4', body: 'Three streams running in parallel.' },
  { time: '3:00 – 4:00 pm', title: 'Session Block 5', body: 'Three streams running in parallel.' },
  { time: '4:00 – 5:00 pm', title: 'Closing Circle', body: 'What we carry forward.' }
];

const audience = [
  'Health and wellness professionals',
  'Educators and researchers',
  'Scientists and environmental advocates',
  'Public-service workers — emergency response, land stewards, and others in community service',
  'Facilitators — Work that Reconnects, Climate Cafes, forest bathing guides, and kindred practices',
  'Faith communities and contemplative practitioners',
  'Artists, organizers, and culture-makers whose work touches the land'
];
---

<BaseLayout
  title={`The Unconference · Fall 2026 | ${site.organizationName}`}
  description="A day-long gathering of nature-connected professionals building intentional community in relationship with nature."
  image="/images/placeholders/hero-nature.svg"
>
  <section
    class="hero-block hero-block--media hero-block--image-first-mobile"
    aria-labelledby="unconference-title"
  >
    <div class="hero-copy">
      <p class="eyebrow">Fall 2026 · Date to be announced</p>
      <h1 id="unconference-title">The Unconference</h1>
      <p class="lead-text">
        A day-long gathering of nature-connected professionals building intentional community in relationship with nature, for our Fall gathering.
      </p>
      <div class="button-row">
        <a class="button" href="https://docs.google.com/forms/d/1Lndw4FCqr-VXUObaYDGUdmATL2TZClI0_Sd6CXyCDA0/edit">Propose a session</a>
        <a class="button button--secondary" href="https://docs.google.com/forms/d/1qcOjkU347HF8yNMVCpQeDqeiUmH1Vv4ERj5MNyOALF0/edit">Get involved</a>
      </div>
    </div>
    <img
      class="placeholder-image placeholder-image--hero"
      src={assetUrl('/images/placeholders/hero-nature.svg')}
      alt="A grove of trees at the edge of a prairie"
      loading="lazy"
    />
  </section>

  <section class="section-stack" aria-labelledby="pillars-title">
    <h2 id="pillars-title">Our three pillars</h2>
    <p>
      The pillars shape what we offer, what we ask of each other, and how we hold the day.
    </p>
    <div class="identity-grid">
      {pillars.map((p) => (
        <article class="identity-item">
          <h3>{p.title}</h3>
          <p>{p.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section-stack" aria-labelledby="streams-title">
    <h2 id="streams-title">A day in three streams</h2>
    <p>
      Each hour has three streams running in parallel. Attendees move between them freely.
    </p>
    <div class="identity-grid">
      {streams.map((s) => (
        <article class="identity-item stream-card">
          <h3>
            <span class="stream-card__icon" aria-hidden="true">{s.icon}</span>
            {s.name}
          </h3>
          <p class="stream-card__kind">{s.kind}</p>
          <p>{s.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section-stack" aria-labelledby="schedule-title">
    <h2 id="schedule-title">Schedule at a glance</h2>
    <p class="lead-text">
      A single-day arc, anchored by an opening and closing circle. Times are approximate and may shift as details firm up.
    </p>
    <ol class="schedule-list">
      {schedule.map((row) => (
        <li class="schedule-item">
          <p class="schedule-item__time">{row.time}</p>
          <div class="schedule-item__body">
            <h3>{row.title}</h3>
            <p>{row.body}</p>
          </div>
        </li>
      ))}
    </ol>
  </section>

  <section class="section-stack" aria-labelledby="place-title">
    <h2 id="place-title">Place &amp; logistics</h2>
    <div class="event-location" aria-label="Location">
      <span class="event-location__icon" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 21s-7-7.5-7-12a7 7 0 1 1 14 0c0 4.5-7 12-7 12z" />
          <circle cx="12" cy="9" r="2.5" />
        </svg>
      </span>
      <span class="event-location__text">RecuperAcres — outdoor gathering land. Full address and directions to be announced with registration.</span>
    </div>
    <ul class="list-flow">
      <li><strong>Outdoors by default</strong>, with a large barn as a weather backup in early October.</li>
      <li><strong>Tent camping welcome</strong> the night before for anyone who wants to land early. Portable stoves are fine; we'll gather around the fire pit by the lake.</li>
      <li><strong>Registration via Eventbrite</strong>, with a sliding-scale ticket and scholarship option so cost is not a barrier.</li>
      <li><strong>Accessibility</strong>: the land has uneven terrain and is not fully wheelchair-accessible. We're mapping access routes and will share details with registration.</li>
      <li><strong>Waiver</strong> signed as part of registration — this is a volunteer-organized event.</li>
    </ul>
  </section>
</BaseLayout>
