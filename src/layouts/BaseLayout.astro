---
import '../styles/global.css';
import { getSiteSettings } from '../lib/content.js';
import { pathMatchesNav, sitePath } from '../lib/sitePath.js';

const site = getSiteSettings();
const {
  title = `${site.organizationName}`,
  description = site.organizationName
} = Astro.props;

function isActiveNavItem(href) {
  return pathMatchesNav(Astro.url.pathname, href);
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to main content</a>

    <div class="page-frame">
      <header class="site-header">
        <div class="wrapper nav-shell">
          <a href={sitePath('/')} class="brand">{site.organizationName}</a>
          <nav aria-label="Main navigation">
            <ul class="main-nav">
              {
                site.navLinks.map((item) => (
                  <li>
                    <a href={sitePath(item.href)} aria-current={isActiveNavItem(item.href) ? 'page' : undefined}>
                      {item.label}
                    </a>
                  </li>
                ))
              }
            </ul>
          </nav>
        </div>
      </header>

      <main id="main-content" class="wrapper content-shell">
        <slot />
      </main>

      <footer class="site-footer">
        <div class="wrapper footer-shell">{site.footerText}</div>
      </footer>
    </div>
  </body>
</html>
